# === Server ===
PORT=8000
NODE_ENV=development

# === Database ===
DATABASE_URL="file:./dev.db"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"
# Saat deploy ke Koyeb, ganti ke connection string Neon:
# DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"  <- pooled, dipakai runtime
# DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"          <- non-pooled, dipakai Prisma migrate

# === JWT Auth ===
JWT_ACCESS_SECRET=ganti_dengan_string_acak_panjang
JWT_REFRESH_SECRET=ganti_dengan_string_acak_panjang_berbeda
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === CORS ===
# Development: http://localhost:5173
# Production: ganti ke domain Vercel kamu, misal https://namakamu.vercel.app
CORS_ORIGIN=http://localhost:5173

# === GitHub API ===
GITHUB_USERNAME=
GITHUB_TOKEN=

# === Admin awal ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=gantiSaatSeeding123