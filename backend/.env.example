# === Server ===
PORT=5000
NODE_ENV=development

# === Database ===
# SQLite untuk development lokal — tidak perlu install apa-apa, cuma file lokal.
DATABASE_URL="file:./dev.db"
# Nanti saat deploy ke Railway, ganti ke PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# === JWT Auth ===
JWT_ACCESS_SECRET=ganti_dengan_string_acak_panjang
JWT_REFRESH_SECRET=ganti_dengan_string_acak_panjang_berbeda
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === CORS ===
# Domain frontend yang diizinkan akses API (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN=http://localhost:5173

# === GitHub API (untuk section GitHub stats) ===
GITHUB_USERNAME=
GITHUB_TOKEN=

# === Admin awal (dipakai sekali saat seeding, lalu boleh dihapus) ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=gantiSaatSeeding123
